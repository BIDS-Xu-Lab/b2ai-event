---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-row">
    <div class="footer-brand">
      <a class="footer-logo" href="https://bridge2ai.org" target="_blank" rel="noopener" aria-label="Bridge2AI home">
        <img src="/b2ai-logo.png" alt="Bridge2AI" width="120" height="48" />
      </a>
      <div class="footer-meta">
        <span class="footer-event">Bridge2AI Fall 2026 All-Hands Meeting &amp; Open House</span>
        <span class="footer-when">October 20–21, 2026 · Rockville, MD</span>
      </div>
    </div>
    <span class="footer-copy">© {year} Bridge2AI Consortium · Funded by the NIH Common Fund</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--b2ai-plum);
    color: #E4D8E6;
    padding: 1.5rem;
    position: relative;
  }
  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(0, 180, 216, 0.4) 50%, transparent 100%);
  }
  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .footer-copy { flex-shrink: 0; }
  .footer-brand { display: flex; align-items: center; gap: 0.9rem; }
  .footer-logo { display: inline-flex; align-items: center; }
  .footer-logo img {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .footer-meta { display: flex; flex-direction: column; gap: 2px; }
  .footer-event {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .footer-when { font-size: var(--text-sm); color: #C9BCD6; }
  .footer-copy {
    font-size: var(--text-sm);
    color: #C7B4C9;
    text-align: right;
  }
  @media (max-width: 640px) {
    .footer-row { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .footer-copy { text-align: left; }
  }
</style>
