---
import Button from './Button.astro';
import HeroBg from './HeroBg.astro';
import PixelBlast from './PixelBlast.jsx';
---
<section class="hero">
  <HeroBg />
  <div class="hero-fx">
    <PixelBlast
      client:load
      variant="square"
      pixelSize={4}
      color="#9A86E6"
      patternScale={2}
      patternDensity={1}
      enableRipples={true}
      rippleSpeed={0.4}
      rippleThickness={0.12}
      rippleIntensityScale={1.4}
      liquid={false}
      speed={0.5}
      edgeFade={0.3}
      transparent={true}
    />
  </div>
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="container hero-inner">
    <span class="hero-eyebrow" data-reveal><span class="hero-dot" aria-hidden="true"></span>Bridge2AI Consortium</span>
    <h1 class="hero-title" data-reveal>
      Bridge2AI Fall 2026<br />All-Hands Meeting <span class="amp">&amp;</span> Open House
    </h1>
    <p class="hero-subtitle" data-reveal>
      <span class="hero-date">October 20–21, 2026</span>
      <span class="hero-sep" aria-hidden="true">|</span>
      <span>Rockville, MD</span>
    </p>
    <div class="hero-cta" data-reveal>
      <Button href="https://web.cvent.com/event/3f4cbe6f-4006-4f79-a2ba-2c4fbf77bae3/summary" variant="cyan">Visit the Event Site</Button>
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--b2ai-navy);
    color: #fff;
    min-height: 600px;
    display: flex;
    align-items: center;
  }
  .hero-fx {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.8;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(16, 10, 46, 0.9) 0%, rgba(16, 10, 46, 0.55) 42%, rgba(16, 10, 46, 0.12) 75%, transparent 100%),
      linear-gradient(180deg, rgba(16, 10, 46, 0.45) 0%, transparent 38%, rgba(16, 10, 46, 0.35) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 3;
    padding: calc(var(--space-9) + 1rem) 1.5rem var(--space-9);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    width: 100%;
  }
  .hero-inner [data-reveal]:nth-child(1) { transition-delay: 0.05s; }
  .hero-inner [data-reveal]:nth-child(2) { transition-delay: 0.14s; }
  .hero-inner [data-reveal]:nth-child(3) { transition-delay: 0.23s; }
  .hero-inner [data-reveal]:nth-child(4) { transition-delay: 0.32s; }
  .scroll-cue {
    position: absolute;
    z-index: 3;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.55);
    animation: bob 2.2s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
  }
  @media (max-width: 760px) {
    .scroll-cue { display: none; }
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(202, 227, 255, 0.07);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #C3CCF2;
  }
  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--b2ai-cyan);
    box-shadow: 0 0 0 4px rgba(0, 180, 216, 0.18);
    flex-shrink: 0;
    animation: hero-dot-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-dot-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(0, 180, 216, 0.22); }
    50% { box-shadow: 0 0 0 6px rgba(0, 180, 216, 0.05); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-dot { animation: none; }
  }
  .hero-title {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
    max-width: none;
    overflow-wrap: break-word;
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.5);
  }
  .amp { color: #B49CF0; }
  .hero-subtitle {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: var(--text-xl);
    font-weight: 500;
    color: #DED6F5;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.45);
  }
  .hero-date { color: #fff; font-weight: 600; }
  .hero-sep { color: rgba(255, 255, 255, 0.3); }
  .hero-cta { margin-top: var(--space-3); }
  .hero-cta :global(svg) { display: none; }

  @media (max-width: 560px) {
    .hero-inner { padding: var(--space-8) 1.5rem; }
    .hero-subtitle { font-size: var(--text-lg); }
  }
  @media (max-width: 380px) {
    .hero-sep { display: none; }
  }
</style>
